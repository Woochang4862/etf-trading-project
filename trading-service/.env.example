# KIS API 설정
KIS_APP_KEY=your_app_key
KIS_APP_SECRET=your_app_secret
KIS_ACCOUNT_NUMBER=00000000-00

# 거래 모드: paper (모의투자) / live (실투자)
TRADING_MODE=paper

# 실투자 안전장치 (live 모드에서 반드시 true)
KIS_LIVE_CONFIRMATION=false

# ML Service URL
ML_SERVICE_URL=http://ml-service:8000

# 전략 파라미터
STRATEGY_RATIO=0.7
FIXED_RATIO=0.3
TOP_N_ETFS=100
CYCLE_TRADING_DAYS=63
ORDER_TYPE=market

# 스케줄러 (KST)
TRADE_HOUR_KST=8
TRADE_MINUTE_KST=30

# DB
LOCAL_DB_PATH=/app/data/trading.db

# API
API_PORT=8002
LOG_LEVEL=INFO
